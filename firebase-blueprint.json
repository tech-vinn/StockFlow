{
  "entities": {
    "StockItem": {
      "title": "Stock Item",
      "description": "An item in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the item" },
        "sku": { "type": "string", "description": "Stock Keeping Unit" },
        "category": { "type": "string", "description": "Category ID or name" },
        "quantity": { "type": "number", "description": "Current stock quantity" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., pcs, kg)" },
        "price": { "type": "number", "description": "Selling Unit price" },
        "cost": { "type": "number", "description": "Cost per unit to purchase" },
        "lowStockThreshold": { "type": "number", "description": "Quantity at which to trigger a low stock alert" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this item" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "quantity", "ownerId", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Stock Transaction",
      "description": "A record of stock moving in or out",
      "type": "object",
      "properties": {
        "itemId": { "type": "string", "description": "ID of the inventory item" },
        "type": { "type": "string", "enum": ["add", "remove", "adjustment"] },
        "quantity": { "type": "number", "description": "Quantity changed" },
        "previousQuantity": { "type": "number", "description": "Quantity before transaction" },
        "newQuantity": { "type": "number", "description": "Quantity after transaction" },
        "unitCost": { "type": "number", "description": "Cost per unit if purchase" },
        "unitPrice": { "type": "number", "description": "Price per unit if sale" },
        "reason": { "type": "string", "description": "Reason for the transaction" },
        "ownerId": { "type": "string", "description": "UID of the user" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "type", "quantity", "ownerId", "timestamp"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "businessName": { "type": "string" },
        "currency": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "joinedAt"]
    }
  },
  "firestore": {
    "inventory": {
      "schema": "StockItem",
      "description": "Live inventory items"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Historical record of stock changes"
    },
    "users": {
      "schema": "UserProfile",
      "description": "User specific data"
    }
  }
}
